# ─────────────────────────────────────────────
# REQUIRED — Copy this to .env and fill in values
# NEVER commit .env to git
# ─────────────────────────────────────────────

# Your wallet private key (deployer + CRE signer for simulation)
CRE_ETH_PRIVATE_KEY=0xYOUR_PRIVATE_KEY_HERE

# CRE target environment
CRE_TARGET=staging-settings

# Gemini API key from https://aistudio.google.com/apikey
GEMINI_API_KEY_VAR=YOUR_GEMINI_API_KEY_HERE

# Sepolia RPC (public node, no key needed)
SEPOLIA_RPC_URL=https://ethereum-sepolia-rpc.publicnode.com

# ─── Tenderly (fill in later for Tenderly deployment) ───
# TENDERLY_RPC_URL=https://virtual.sepolia.rpc.tenderly.co/YOUR_VNET_ID
# TENDERLY_ACCESS_KEY=YOUR_TENDERLY_ACCESS_KEY
# TENDERLY_PROJECT=YOUR_PROJECT_SLUG
# TENDERLY_ACCOUNT=YOUR_ACCOUNT_SLUG